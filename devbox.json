{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "beam.packages.erlang_28.elixir_1_19",
    "fwup@latest",
    "squashfsTools@latest"
  ],
  "shell": {
    "init_hook": [
      "ls \"$MIX_HOME/archives\"/hex-* >/dev/null 2>&1 || mix local.hex --force",
      "ls \"$MIX_HOME/archives\"/nerves_bootstrap-*  >/dev/null 2>&1 || mix archive.install hex nerves_bootstrap --force"
    ]
  },
  "include": ["plugin:elixir"]
}
