# Additional configuration for erlinit

# UART console
-c ttyFIQ0
--warn-unused-tty

# Enable UTF-8 filename handling in Erlang and custom inet configuration
-e LANG=en_US.UTF-8;LANGUAGE=en;ERL_INETRC=/etc/erl_inetrc

# Enable crash dumps
-e ERL_CRASH_DUMP=/root/erl_crash.dump;ERL_CRASH_DUMP_SECONDS=5

# Mount writable and support filesystems
-m /dev/mmcblk1p4:/boot:vfat:ro,nodev,noexec,nosuid:
-m /dev/mmcblk1p6:/root:ext4:nodev:
-m tmpfs:/tmp:tmpfs:nodev,nosuid:mode=1777,size=16m
-m configfs:/sys/kernel/config:configfs:nodev,noexec,nosuid:
-m tmpfs:/sys/fs/cgroup:tmpfs:nodev,noexec,nosuid:mode=755,size=1024k

# Erlang release search path
-r /srv/erlang

# Start shoehorn first if present
--boot shoehorn
